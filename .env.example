# Application settings
NOTIFYSTACK_APP_NAME="NotifyStack OSS"
NOTIFYSTACK_API_V1_PREFIX="/api/v1"

# Database connection URL
# For local postgres via docker-compose use:
# postgresql+asyncpg://postgres:postgres@localhost:5432/notifystack
NOTIFYSTACK_DATABASE_URL="sqlite+aiosqlite:///./notifystack.db"

# JWT Auth settings
# Must be at least 32 characters long
NOTIFYSTACK_JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars-long"
NOTIFYSTACK_JWT_ALGORITHM="HS256"
NOTIFYSTACK_ACCESS_TOKEN_EXP_MINUTES=30
NOTIFYSTACK_REFRESH_TOKEN_EXP_MINUTES=10080
